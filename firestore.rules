rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 共有メモ ──────────────────────────────────────────────────────────────
    // ownerUid / collaboratorUids による Firebase Auth UID ベースのアクセス制御。
    // 移行期間中: ownerUid が未設定の既存ドキュメントは従来通り認証済みユーザーに許可。
    match /sharedMemos/{shareId} {

      // 移行期間ヘルパー: ownerUid がまだ設定されていない既存ドキュメント
      // TODO: 2026-06-30 までに既存ドキュメントへ ownerUid を付与する移行スクリプトを実行し、
      //       この isLegacyDoc() フォールバックを削除すること。
      //       フォールバックが残っている間、認証済みユーザー全員がレガシードキュメントにアクセス可能。
      function isLegacyDoc() {
        return !('ownerUid' in resource.data);
      }

      // 読み取り: 認証済みユーザーであれば誰でも可。
      // 共有コード（= Firestore ドキュメント ID）を知っていること自体がアクセス権の証明。
      // joinSharedMemo() で共有コードを入力した新規ユーザーが、まだ collaboratorUids に
      // 登録される前にドキュメントを読み取る必要があるため、read は広く許可する。
      allow read: if request.auth != null;

      // 新規作成: ownerUid が自分の UID と一致すること + 必須フィールド検証
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['title', 'items', 'ownerDeviceId', 'collaborators', 'updatedAt', 'ownerUid', 'collaboratorUids'])
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.collaboratorUids
        && request.resource.data.collaboratorUids.size() <= 21
        && request.resource.data.collaborators.size() <= 21
        && request.resource.data.items.size() <= 100;

      // self-join ヘルパー: collaboratorUids / collaborators に自分を追加するだけの更新か判定。
      // joinSharedMemo() で受信者が自分の UID を追加する際、まだ collaboratorUids に
      // 含まれていないためメインの update ルールに弾かれる問題を回避する。
      function isSelfJoin() {
        return request.resource.data.collaboratorUids is list
          && request.auth.uid in request.resource.data.collaboratorUids
          && (!('collaboratorUids' in resource.data)
              || !(request.auth.uid in resource.data.collaboratorUids))
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['collaborators', 'collaboratorUids']);
      }

      // 更新: オーナーまたは参加者（移行期間中は認証済みユーザー）
      // ownerDeviceId と ownerUid の書き換えは禁止
      // self-join: 共有メモの読み取り権限を持つユーザーが自分を collaboratorUids に追加する場合も許可
      allow update: if request.auth != null
        && (isLegacyDoc()
            || resource.data.ownerUid == request.auth.uid
            || (resource.data.collaboratorUids is list
                && request.auth.uid in resource.data.collaboratorUids)
            || isSelfJoin())
        && request.resource.data.ownerDeviceId == resource.data.ownerDeviceId
        && (!('ownerUid' in resource.data) || request.resource.data.ownerUid == resource.data.ownerUid)
        && request.resource.data.collaborators.size() <= 21
        && (!('collaboratorUids' in request.resource.data) || request.resource.data.collaboratorUids.size() <= 21)
        && request.resource.data.items.size() <= 100;

      // 削除: オーナーのみ（移行期間中は認証済みユーザー）
      allow delete: if request.auth != null
        && (isLegacyDoc()
            || resource.data.ownerUid == request.auth.uid);
    }

    // ── クーポンコード ────────────────────────────────────────────────────────
    // 書き込みは「used: false → true」のみ許可（トランザクションで使用）
    match /couponCodes/{code} {
      // 読み取り: 認証済みユーザーのみ（コードの有効性確認用）
      allow read: if request.auth != null;

      // 作成・削除: クライアントから不可（Firebase Console / Admin SDK のみ）
      allow create, delete: if false;

      // 更新: used フラグを false → true に変更する場合のみ許可
      allow update: if request.auth != null
        && request.resource.data.used == true
        && resource.data.used == false
        && request.resource.data.keys().hasOnly(resource.data.keys());
    }

    // ── クラウドバックアップ（プレミアム機能）──────────────────────────────────
    // ownerUid で所有者を検証し、自分のバックアップのみアクセス可能
    match /backups/{deviceId} {
      // 新規作成: ownerUid が自分の UID と一致すること
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;

      // 読み取り・更新・削除: 既存ドキュメントの ownerUid が自分の UID と一致すること
      allow read, update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    // ── FCM デバイストークン ────────────────────────────────────────────
    // ドキュメントID = Firebase Auth UID。自分のトークンのみ CRUD 可能。
    // Cloud Functions (Admin SDK) はルールをバイパスするため、
    // notifyCollaborators 関数からの読み取りには影響しない。
    match /deviceTokens/{uid} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid;
    }

    // ── YOAKE 睡眠アプリ ──────────────────────────────────────────────────────
    // ユーザーデータ: サブコレクションを明示列挙してアクセス制御

    // users ルートドキュメント（isPremium フラグ）: 本人読み取りのみ（書き込みは Admin SDK のみ）
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // FCMトークン: 本人のみ読み書き可
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // プロフィール・目標: 本人のみ読み書き可
    match /users/{userId}/profile/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/goal/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // サブスクリプション: 本人読み取りのみ（書き込みは Cloud Functions Admin SDK のみ）
    match /users/{userId}/subscription/{doc} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // 睡眠ログ: 本人のみ（memo は 500 文字以内）
    // Note: delete は request.resource が null になるため create/update と分離する
    match /users/{userId}/sleepLogs/{doc} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId
        && (request.resource.data.memo == null
            || request.resource.data.memo.size() <= 500);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/aiReports/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/habitTemplates/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/chatHistory/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/bodyLogs/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // チャット使用回数: 本人読み取りのみ（書き込みは Cloud Functions Admin SDK のみ）
    match /users/{userId}/chatUsage/{doc} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // トライアル利用履歴: クライアントはアクセス不可（Cloud Functions Admin SDK のみ）
    match /trialUsage/{deviceId} {
      allow read, write: if false;
    }

    // アプリ共通データ: 認証済みなら読み取り可（書き込み不可）
    match /appData/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // その他のコレクションはすべて拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
