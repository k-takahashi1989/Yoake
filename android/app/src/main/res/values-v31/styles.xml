<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+: システムスプラッシュのアイコンを非表示にして背景色のみにする -->
    <!-- RNBootSplashView（フルスクリーン画像）が直後に表示されるため、チラつきを防ぐ -->
    <style name="BootTheme" parent="Theme.BootSplash">
        <item name="bootSplashBackground">@color/bootsplash_background</item>
        <item name="bootSplashLogo">@drawable/bootsplash_logo</item>
        <item name="postBootSplashTheme">@style/AppTheme</item>
        <item name="android:windowSplashScreenBackground">@color/bootsplash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/transparent</item>
    </style>
</resources>
